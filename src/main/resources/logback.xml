<configuration>
  <conversionRule conversionWord="memory_usage" class="io.github.dsheirer.util.MemoryUsageLogger" />

  <timestamp key="appstart" datePattern="HHmmss"/>

  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%-12(%d{yyyy-MM-dd HH:mm:ss.SSS}) %-5level %logger{25} - %msg  %memory_usage%n</pattern>
    </encoder>
  </appender>
          
  <root level="INFO">
    <appender-ref ref="STDOUT" />
  </root>

  <!-- Apache Mina TCP/HTTP library -->
  <logger name="org.apache.mina" level="INFO" />

  <!-- Zello: DEBUG exposes all activity including transient server errors
       (invalid stream id, failed to start/stop stream, opus hiccups, reconnects,
       session-epoch drops). Change to INFO if the log becomes too noisy. -->
  <logger name="io.github.dsheirer.audio.broadcast.zello" level="DEBUG" />

  <!-- ThinLine Radio: DEBUG for streaming diagnostics. Change to INFO if noisy. -->
  <logger name="io.github.dsheirer.audio.broadcast.thinlineradio" level="DEBUG" />

</configuration>